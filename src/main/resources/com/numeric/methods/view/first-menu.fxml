<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.numeric.methods.controllers.firstMenuController">
    <children>
        <Label text="Menú de Métodos" />
        <GridPane hgap="20" vgap="15" alignment="CENTER">
            <Button fx:id="convertionButton" text="Convertir" onAction="#switchToConvertion" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Button fx:id="bisectionButton" text="Bisección" onAction="#switchToBisection" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Button fx:id="fixPointButton" text="Punto Fijo" onAction="#switchToFixPoint" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <Button fx:id="newtonRaphsonButton" text="Newton-Raphson" onAction="#switchToNewtonRaphson" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Button fx:id="falsePositionButton" text="Falsa Posición" onAction="#switchToFalsePosition" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <Button fx:id="secantButton" text="Secante" onAction="#switchToSecant" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Button fx:id="mullerButton" text="Muller" onAction="#switchToMuller" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <Button fx:id="deflationButton" text="Deflación" onAction="#switchToDeflation" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </GridPane>
        <VBox alignment="CENTER" spacing="40.0">
            <Button fx:id="backButton" text="Volver" onAction="#switchToMain" alignment="CENTER" />
        </VBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
